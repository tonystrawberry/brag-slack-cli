# Required: Slack user OAuth token (xoxp-...) with scopes: search:read, channels:history, groups:history, im:history, mpim:history, users:read
SLACK_USER_TOKEN=xoxp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Gemini API key for generating the brag summary (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: If auth.test doesn't return your user (e.g. bot token), set your Slack email to resolve "me"
BRAG_SLACK_EMAIL=you@company.com

# Optional: LLM model (default: gemini-2.0-flash)
BRAG_LLM_MODEL=gemini-3.1-flash-lite-preview

# Optional: Max conversation snippets to fetch (default: 150). Reduces API calls; increase if you want more coverage.
BRAG_MAX_SNIPPETS=200

# Optional: Cache fetched snippets on disk (BRAG_CACHE=1). Cache is stored in .brag-cache/; use --no-cache to bypass.
BRAG_CACHE=1

# Optional: Output language for the summary (en | ja). Default: en. Can be overridden with --lang.
BRAG_LANG=ja

# Optional: Max concurrent snippet fetches (default: 8). Higher = faster but more load on Slack API; use 1 for sequential.
BRAG_FETCH_CONCURRENCY=8
